# Database — Prisma connection string
# For Docker: host = "postgres" (service name in docker-compose)
# For local dev: host = "localhost"
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/paycircle

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Email (Gmail app password for OTP)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password
